# Optional hardening drop-in for the miru agent.
# Copy to /etc/systemd/system/miru.service.d/lockdown.conf. Edit the
# ReadWritePaths= line to list the directories the agent should be
# allowed to write, then run:
#     sudo systemctl daemon-reload
#     sudo systemctl restart miru.service
[Service]
ProtectSystem=strict
ProtectHome=true
# replace these paths with your actual paths
ReadWritePaths=/etc/myapp /var/lib/myapp
